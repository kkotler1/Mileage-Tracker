# Google service account JSON file (reuse the one from receipt-extractor if you have it,
# or create a new one in Google Cloud Console > IAM > Service Accounts).
# The service account's email must have Editor access to the target spreadsheet.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Spreadsheet ID (the long string in the Sheet URL: /spreadsheets/d/<THIS>/edit).
GOOGLE_SHEET_ID=

# Tab name inside the spreadsheet. Auto-created on first write.
MILEAGE_TAB_NAME=Trips

# Where to store the locations cache (one-way miles_from_home per place).
LOCATIONS_FILE=~/.mileage_locations.json

# IRS standard mileage rate in dollars per mile. Update annually.
# 2024: 0.67, 2025: 0.70, 2026: confirm at irs.gov before tax filing.
IRS_MILEAGE_RATE=0.70

# MCP transport. stdio for Claude Code; streamable-http for remote deploys.
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8765

# OAuth (WorkOS AuthKit) — required for the claude.ai connector, which mandates
# OAuth 2.1 + Dynamic Client Registration. Set BOTH to enable auth on the public
# http server; leave AUTHKIT_DOMAIN blank to run authless (stdio/local stays
# authless regardless). claude.ai registers against WorkOS; this server only
# validates the issued tokens. Served at the Funnel root, so PUBLIC_BASE_URL is
# the bare domain (no path).
AUTHKIT_DOMAIN=
PUBLIC_BASE_URL=https://minisforum.tail2b7516.ts.net
